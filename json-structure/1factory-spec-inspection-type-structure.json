{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/1factory/refs/heads/main/json-structure/1factory-spec-inspection-type-structure.json",
  "name": "SpecInspectionType",
  "description": "SpecInspectionType schema from 1Factory API",
  "type": "object",
  "properties": {
    "inspection_type": {
      "$ref": "#/components/schemas/inspection_type"
    },
    "inspection_method": {
      "type": "string",
      "nullable": true,
      "description": "How the feature should be inspected.",
      "example": "CMM"
    },
    "sampling_rule": {
      "type": "string",
      "nullable": true,
      "description": "How frequently should the feature be checked.",
      "example": "1 in 10"
    },
    "data_type": {
      "type": "string",
      "nullable": false,
      "enum": [
        "NUM",
        "P/F",
        "CALC"
      ],
      "description": "How the data for this specification is recorded - numerically, as a pass/fail, or calculated from other features.",
      "example": "NUM"
    }
  }
}